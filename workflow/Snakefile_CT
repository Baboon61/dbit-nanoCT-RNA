        bam = proc_dir + '{sample}/{modality}_{barcode}/cellranger/outs/namesorted_bam.bam',
        infile = proc_dir + '{sample}/{modality}_{barcode}/cellranger/outs/namesorted_bam.done',
    output:
        bam = temp(proc_dir + '{sample}/{modality}_{barcode}/cellranger/outs/namesorted_noLA_duplicates_bam.bam'),
        outfile = touch(proc_dir + '{sample}/{modality}_{barcode}/cellranger/outs/namesorted_noLA_duplicates_bam.done'),
    params:
        script = workflow.basedir + '/scripts/remove_LA_duplicates.py',
    conda: '../envs/dbit-spatial-nanoct-rna-debarcode.yaml'
    resources:
        mem_mb = 32000
    shell:
        'python3 {params.script} {input.bam} {output.bam}'

rule possort_noLA_bam_file:
    input:
        bam = proc_dir + '{sample}/{modality}_{barcode}/cellranger/outs/namesorted_noLA_duplicates_bam.bam',
        infile = proc_dir + '{sample}/{modality}_{barcode}/cellranger/outs/namesorted_noLA_duplicates_bam.done',
    output:
        bam   = temp(proc_dir + '{sample}/{modality}_{barcode}/cellranger/outs/possorted_noLA_duplicates_bam.bam'),
        index = temp(proc_dir + '{sample}/{modality}_{barcode}/cellranger/outs/possorted_noLA_duplicates_bam.bam.bai'),
        outfile = touch(proc_dir + '{sample}/{modality}_{barcode}/cellranger/outs/possorted_noLA_duplicates_bam.done'),
    conda: '../envs/dbit-spatial-nanoct-rna-samtools.yaml'
    threads: 20
    resources:
        mem_mb = 32000
    params:
        tempfolder = config['general']['tempdir']
    shell:
        'samtools sort -@ {threads} -T {params.tempfolder} -o {output.bam} {input.bam}; '
        'samtools index {output.bam} '

rule bam_noLA_to_fragments_noLA:
    input:
        bam = proc_dir + '{sample}/{modality}_{barcode}/cellranger/outs/possorted_noLA_duplicates_bam.bam',
        index= proc_dir + '{sample}/{modality}_{barcode}/cellranger/outs/possorted_noLA_duplicates_bam.bam.bai',
        infile = proc_dir + '{sample}/{modality}_{barcode}/cellranger/outs/possorted_noLA_duplicates_bam.done',
    output:
        fragmments = temp(proc_dir + '{sample}/{modality}_{barcode}/cellranger/outs/fragments_noLA_duplicates.tsv'),
        outfile = touch(proc_dir + '{sample}/{modality}_{barcode}/cellranger/outs/fragments_noLA_duplicates.tsv.done'),
    conda: '../envs/dbit-spatial-nanoct-rna-sinto.yaml'
    threads: 20
    resources:
        mem_mb=16000
    shell:
        'sinto fragments -b {input.bam} -f {output.fragmments} -p {threads}'

rule sort_sinto_output:
    input:
        fragments = proc_dir + '{sample}/{modality}_{barcode}/cellranger/outs/fragments_noLA_duplicates.tsv',
        infile = proc_dir + '{sample}/{modality}_{barcode}/cellranger/outs/fragments_noLA_duplicates.tsv.done',
    output:
        fragments = proc_dir + '{sample}/{modality}_{barcode}/cellranger/outs/fragments_noLA_duplicates.tsv.gz',
        index      = proc_dir + '{sample}/{modality}_{barcode}/cellranger/outs/fragments_noLA_duplicates.tsv.gz.tbi',
        outfile = touch(proc_dir + '{sample}/{modality}_{barcode}/cellranger/outs/fragments_noLA_duplicates.tsv.gz.done'),
    conda: '../envs/dbit-spatial-nanoct-rna-samtools.yaml'
    resources:
        mem_mb = 16000
    shell:
        'sort -k1,1 -k2,2n {input.fragments} | bgzip > {output.fragments}; '
        'tabix -p bed {output.fragments} '

rule bam_to_bw:
    input:
        cellranger_bam = proc_dir + '{sample}/{modality}_{barcode}/cellranger/outs/possorted_bam.bam',
        cellranger_bai = proc_dir + '{sample}/{modality}_{barcode}/cellranger/outs/possorted_bam.bam.bai',
        infile = proc_dir + '{sample}/{modality}_{barcode}/{sample}_run_cellranger.done',
    output:
        bigwig = proc_dir + '{sample}/{modality}_{barcode}/bigwig/all_reads.bw',
        outfile = touch(proc_dir + '{sample}/{modality}_{barcode}/bigwig/all_reads.bw.done'),
    threads: 20
    conda: '../envs/dbit-spatial-nanoct-rna-bamcoverage.yaml'
    resources:
        mem_mb = 16000
    shell:
        'bamCoverage -b {input.cellranger_bam} -o {output.bigwig} -p {threads} --minMappingQuality 5 '
        ' --binSize 50 --centerReads --smoothLength 250 --normalizeUsing RPKM --ignoreDuplicates --extendReads'

rule run_macs_broad:
    input:
        cellranger_bam=proc_dir + '{sample}/{modality}_{barcode}/cellranger/outs/possorted_bam.bam',
        infile = proc_dir + '{sample}/{modality}_{barcode}/{sample}_run_cellranger.done',
    output:
        broad_peaks=proc_dir + '{sample}/{modality}_{barcode}/peaks/macs_broad/{modality}_peaks.broadPeak',
        outfile = touch(proc_dir + '{sample}/{modality}_{barcode}/peaks/macs_broad/{modality}_peaks.broadPeak.done'),
    params:
        macs_outdir=proc_dir + '{sample}/{modality}_{barcode}/peaks/macs_broad/',
        macs_genome=config['general']['macs_genome']
    conda: '../envs/dbit-spatial-nanoct-rna-macs.yaml'
    resources:
        mem_mb = 16000
    shell:
        'macs2 callpeak -t {input.cellranger_bam} -g {params.macs_genome} -f BAMPE -n {wildcards.modality} '
        '--outdir {params.macs_outdir} --llocal 100000 --keep-dup 1 --broad-cutoff 0.1 '
        '--max-gap 1000 --broad 2>&1 '

rule barcode_metrics_peaks:
    input:
        bam=proc_dir + '{sample}/{modality}_{barcode}/cellranger/outs/possorted_bam.bam',
        peaks=proc_dir + '{sample}/{modality}_{barcode}/peaks/macs_broad/{modality}_peaks.broadPeak',
        infile1 = proc_dir + '{sample}/{modality}_{barcode}/{sample}_run_cellranger.done',
        infile2 = proc_dir + '{sample}/{modality}_{barcode}/peaks/macs_broad/{modality}_peaks.broadPeak.done',
    output:
        overlap=proc_dir + '{sample}/{modality}_{barcode}/barcode_metrics/peaks_barcodes.txt',
        outfile = touch(proc_dir + '{sample}/{modality}_{barcode}/barcode_metrics/peaks_barcodes.txt.done'),
    params:
        get_cell_barcode=workflow.basedir + '/scripts/awk/get_cell_barcode.awk',
        tmpdir=config['general']['tempdir']
    conda: '../envs/dbit-spatial-nanoct-rna-samtools.yaml'
    resources:
        mem_mb = 16000
    shell:
        'bedtools intersect -abam {input.bam} -b {input.peaks} -u | samtools view -f2 | '
        'awk -f {params.get_cell_barcode} | sed "s/CB:Z://g" |  '
        'sort -T {params.tmpdir} | uniq -c > {output.overlap} && [[ -s {output.overlap} ]] ; '

rule barcode_metrics_all:
    input:
        bam=proc_dir + '{sample}/{modality}_{barcode}/cellranger/outs/possorted_bam.bam',
        infile = proc_dir + '{sample}/{modality}_{barcode}/{sample}_run_cellranger.done',
    output:
        all_bcd=proc_dir + '{sample}/{modality}_{barcode}/barcode_metrics/all_barcodes.txt',
        outfile = touch(proc_dir + '{sample}/{modality}_{barcode}/barcode_metrics/all_barcodes.txt.done'),
    params:
        get_cell_barcode=workflow.basedir + '/scripts/awk/get_cell_barcode.awk',
        tmpdir=config['general']['tempdir']
    conda: '../envs/dbit-spatial-nanoct-rna-samtools.yaml'
    resources:
        mem_mb = 16000
    shell:
        'mkdir -p {params.tmpdir}; '
        'samtools view -f2 {input.bam}| '
        'awk -f {params.get_cell_barcode} | sed "s/CB:Z://g" |  '
        'sort -T {params.tmpdir} | uniq -c > {output.all_bcd} && [[ -s {output.all_bcd} ]] ; '

rule clean_cellranger_output:
    input:
        bam = proc_dir + '{sample}/{modality}_{barcode}/cellranger/outs/possorted_bam.bam',
        frag = proc_dir + '{sample}/{modality}_{barcode}/cellranger/outs/fragments.tsv.gz',
        meta = proc_dir + '{sample}/{modality}_{barcode}/cellranger/outs/singlecell.csv',
        peaks = proc_dir + '{sample}/{modality}_{barcode}/cellranger/outs/peaks.bed',
        infile = proc_dir + '{sample}/{modality}_{barcode}/{sample}_run_cellranger.done',
    output:
        outfile = touch(proc_dir + '{sample}/{modality}_{barcode}/clean_cellranger.done')
    params:
        cellranger_folder = proc_dir + '{sample}/{modality}_{barcode}/cellranger/'
    shell:
        'find {params.cellranger_folder} -mindepth 1 -maxdepth 1 ! -name outs -exec rm -rf {{}} +; '

rule spatial_barcodes_to_cells:
    input:
        spatial_barcodes = config['general']['spatial_barcodes_file']
    output:
        cells = proc_dir + 'all_spatial_cells.txt',
        outfile = touch(proc_dir + 'all_spatial_cells.done'),
    params:
        add_1_to_cells = workflow.basedir + '/scripts/awk/add_1_to_cells.awk'
    shell:
        'awk -f {params.add_1_to_cells.awk} {input.spatial_barcodes} > {output.cells}'

rule create_matrix_peaks:
    # Requires fragtk installation (https://github.com/stuart-lab/fragtk)
    input:
        frag  = proc_dir + '{sample}/{modality}_{barcode}/cellranger/outs/fragments.tsv.gz',
        peaks = proc_dir + '{sample}/{modality}_{barcode}/peaks/macs_broad/{modality}_peaks.broadPeak',
        cells = proc_dir + 'all_spatial_cells.txt',
        infile1 = proc_dir + '{sample}/{modality}_{barcode}/{sample}_run_cellranger.done',
        infile2 = proc_dir + '{sample}/{modality}_{barcode}/peaks/macs_broad/{modality}_peaks.broadPeak.done',
        infile3 = proc_dir + 'all_spatial_cells.done',
    output:
        features = proc_dir + '{sample}/{modality}_{barcode}/matrix/matrix_peaks/features.tsv.gz',
        matrix   = proc_dir + '{sample}/{modality}_{barcode}/matrix/matrix_peaks/matrix.mtx.gz',
        barcodes = proc_dir + '{sample}/{modality}_{barcode}/matrix/matrix_peaks/barcodes.tsv',
        folder   = directory(proc_dir + '{sample}/{modality}_{barcode}/matrix/matrix_peaks/'),
        outfile = touch(proc_dir + '{sample}/{modality}_{barcode}/matrix/matrix_peaks.done'),
    conda: '../envs/dbit-spatial-nanoct-rna-samtools.yaml'
    params:
        matrix_dir = proc_dir + '{sample}/{modality}_{barcode}/matrix/',
        fragtk = config['general']['fragtk_bin'],
    shell:
        'mkdir -p {params.matrix_dir}; '
        '{params.fragtk} matrix -f {input.frag} -b {input.peaks} -c {input.cells} -o {output.folder}'

rule create_matrix_bins:
    input:
        bam   = proc_dir + '{sample}/{modality}_{barcode}/cellranger/outs/possorted_bam.bam',
        bai   = proc_dir + '{sample}/{modality}_{barcode}/cellranger/outs/possorted_bam.bam.bai',
        frag  = proc_dir + '{sample}/{modality}_{barcode}/cellranger/outs/fragments.tsv.gz',
        cells = proc_dir + 'all_spatial_cells.txt',
        infile1 = proc_dir + '{sample}/{modality}_{barcode}/{sample}_run_cellranger.done',
        infile2 = proc_dir + 'all_spatial_cells.done',
    output:
        features   = proc_dir + '{sample}/{modality}_{barcode}/matrix/matrix_bin_{bins}/features.tsv.gz',
        matrix     = proc_dir + '{sample}/{modality}_{barcode}/matrix/matrix_bin_{bins}/matrix.mtx.gz',
        barcodes   = proc_dir + '{sample}/{modality}_{barcode}/matrix/matrix_bin_{bins}/barcodes.tsv',
        folder     = directory(proc_dir + '{sample}/{modality}_{barcode}/matrix/matrix_bin_{bins}/'),
        chromsizes = temp(proc_dir + '{sample}/{modality}_{barcode}/chromsizes_{bins}.txt'),
        windows    = temp(proc_dir + '{sample}/{modality}_{barcode}/windows_{bins}.txt'),
        outfile    = touch(proc_dir + '{sample}/{modality}_{barcode}/matrix/matrix_bin_{bins}.done'),
    conda: '../envs/dbit-spatial-nanoct-rna-samtools.yaml'
    params:
        get_chrom_sizes = workflow.basedir + '/scripts/awk/get_chrom_sizes.awk',
        matrix_dir = proc_dir + '{sample}/{modality}_{barcode}/matrix/',
        fragtk = config['general']['fragtk_bin'],
    shell:
        """
        mkdir -p {params.matrix_dir};
        samtools idxstats {input.bam} | awk -f {params.get_chrom_sizes} > {output.chromsizes};
        bedtools makewindows -g {output.chromsizes} -w {wildcards.bins} > {output.windows};
        {params.fragtk} matrix -f {input.frag} -b {output.windows} -c {input.cells} -o {output.folder};
        """
    
rule create_genebody_and_promoter_matrix:
    input:
        cellranger_gtf = config['general']['cellranger']['reference_path'] + 'genes/genes.gtf.gz',
        frag           = proc_dir + '{sample}/{modality}_{barcode}/cellranger/outs/fragments.tsv.gz',
        cells          = proc_dir + 'all_spatial_cells.txt',
        infile1        = proc_dir + '{sample}/{modality}_{barcode}/{sample}_run_cellranger.done',
        infile2        = proc_dir + 'all_spatial_cells.done',
    output:
        genebody_gtf = proc_dir + '{sample}/{modality}_{barcode}/matrix/matrix_genes/genebody_and_promoter.gtf',
        genebody_bed = proc_dir + '{sample}/{modality}_{barcode}/matrix/matrix_genes/genebody_and_promoter.bed',
        gene_names   = proc_dir + '{sample}/{modality}_{barcode}/matrix/matrix_genes/gene_names.txt',
        features     = proc_dir + '{sample}/{modality}_{barcode}/matrix/matrix_genes/features.tsv.gz',
        matrix       = proc_dir + '{sample}/{modality}_{barcode}/matrix/matrix_genes/matrix.mtx.gz',
        barcodes     = proc_dir + '{sample}/{modality}_{barcode}/matrix/matrix_genes/barcodes.tsv',
        folder       = directory(proc_dir + '{sample}/{modality}_{barcode}/matrix/matrix_genes/'),
        outfile      = touch(proc_dir + '{sample}/{modality}_{barcode}/matrix/matrix_genes.done'),
    conda: '../envs/dbit-spatial-nanoct-rna-samtools.yaml'
    params:
        script = workflow.basedir + '/scripts/filter_cellranger_gtf_file.py',
        matrix_dir = proc_dir + '{sample}/{modality}_{barcode}/matrix/',
        fragtk = config['general']['fragtk_bin'],
    shell:
        """
        mkdir -p {params.matrix_dir};
        python3 {params.script} -i {input.cellranger_gtf} -o {output.genebody_gtf} -n {output.gene_names};
        cut -f 1,4,5 {output.genebody_gtf} > {output.genebody_bed};
        {params.fragtk} matrix -f {input.frag} -b {output.genebody_bed} -c {input.cells} -o {output.folder};
        """
