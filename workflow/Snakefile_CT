include: 'Snakefile_prep_CT.smk'
include: 'Snakefile_paths.smk'

# Final CT targets. Most entries are .done gatekeepers so downstream rules wait
# for upstream rules to finish completely, not just for a data file to appear.
rule all:
  input:
    filterPCR=[
      qc_fastq(res['id'], res['number'], res['lane'], 'R1', 'raw_qc_primer', res['suffix'], res['ext']) \
      for sample_id in samples_list for res in get_fastq_info_from_folder(raw_dir, sample_id)
    ],
    filterL1=[
      qc_fastq(res['id'], res['number'], res['lane'], 'R1', 'raw_qc_linker1', res['suffix'], res['ext']) \
      for sample_id in samples_list for res in get_fastq_info_from_folder(raw_dir, sample_id)
    ],
    filterL2=[
      qc_fastq(res['id'], res['number'], res['lane'], 'R1', 'raw_qc_linker2', res['suffix'], res['ext']) \
      for sample_id in samples_list for res in get_fastq_info_from_folder(raw_dir, sample_id)
    ],
    bc_process=[
      tmp_fastq(res['id'], res['number'], res['lane'], 'R2', res['suffix'], res['ext']) \
      for sample_id in samples_list for res in get_fastq_info_from_folder(raw_dir, sample_id)
    ],
    seq_file_rename=[
      tmp_fastq(sample_id, res['number'], res['lane'], 'R3', res['suffix'], res['ext']) \
      for sample_id in samples_list for res in get_fastq_info_from_folder(raw_dir, sample_id)
    ],
    debarcode=[
      ct_debarcoded_fastq(res['id'], modality, barcodes_dict[res['id']][modality], res['number'], res['lane'], 'R1', res['suffix'], res['ext']) \
      for sample_id in samples_list for modality in barcodes_dict[sample_id].keys() for res in get_fastq_info_from_folder(raw_dir, sample_id)
    ],
    get_barcodes_cellranger=[
      global_done('get_barcodes_cellranger')
    ],
    run_cellranger=[
      modality_done(sample_id, modality, barcodes_dict[sample_id][modality], 'run_cellranger') \
      for sample_id in samples_list for modality in barcodes_dict[sample_id].keys()
    ],
    restore_cellranger_barcodes=[
      global_done('restore_cellranger_barcodes')
    ],
    bigwig_all=[
      modality_done(sample_id, modality, barcodes_dict[sample_id][modality], 'bam_to_bw') \
      for sample_id in samples_list for modality in barcodes_dict[sample_id].keys()
    ],
    macs_broad=[
      modality_done(sample_id, modality, barcodes_dict[sample_id][modality], 'macs_broad') \
      for sample_id in samples_list for modality in barcodes_dict[sample_id].keys()
    ],
    barcodes_sum=[
      modality_done(sample_id, modality, barcodes_dict[sample_id][modality], 'barcode_metrics_all') \
      for sample_id in samples_list for modality in barcodes_dict[sample_id].keys()
    ],
    noLA_bam=[
      modality_done(sample_id, modality, barcodes_dict[sample_id][modality], 'sort_noLA_fragments') \
      for sample_id in samples_list for modality in barcodes_dict[sample_id].keys()
    ],
    cellranger_cleanup = [
      modality_done(sample_id, modality, barcodes_dict[sample_id][modality], 'clean_cellranger') \
      for sample_id in samples_list for modality in barcodes_dict[sample_id].keys()
    ],
    matrix_peaks = [
      modality_done(sample_id, modality, barcodes_dict[sample_id][modality], 'matrix_peaks') \
      for sample_id in samples_list for modality in barcodes_dict[sample_id].keys()
    ],
    matrix_bins = [
      modality_done(sample_id, modality, barcodes_dict[sample_id][modality], 'matrix_bin_{binsize}'.format(binsize=binsize)) \
      for sample_id in samples_list for modality in barcodes_dict[sample_id].keys() for binsize in config['general']['bin_sizes']
    ],
    matrix_genes = [
      modality_done(sample_id, modality, barcodes_dict[sample_id][modality], 'matrix_genes') \
      for sample_id in samples_list for modality in barcodes_dict[sample_id].keys()
    ],

include: 'Snakefile_spatial_demux.smk'

# Build synthetic CT R1/R2 reads from the barcode-containing read.
# R1 becomes the sequence read and R2 carries modality/Tn5/spatial barcode data.
rule bc_process:
  input:
    script = workflow.basedir + '/scripts/BC_process_CT.py',
    in1 = lambda wildcards: qc_fastq(wildcards.sample, wildcards.number, wildcards.lane, Rfile_barcode, 'raw_qc_linker2', wildcards.suffix, wildcards.ext),
    infile = lambda wildcards: qc_done(wildcards.sample, wildcards.number, wildcards.lane, wildcards.suffix, wildcards.ext, 'filter_L2')
  output:
    out1 = tmp_fastq('{sample}', '{number}', '{lane}', 'R1', '{suffix}', '{ext}'),
    out2 = tmp_fastq('{sample}', '{number}', '{lane}', 'R2', '{suffix}', '{ext}'),
    outfile = touch(tmp_done('{sample}', '{number}', '{lane}', '{suffix}', '{ext}', 'bc_process'))
  log:
    sample_lane_log('{sample}', '{number}', '{lane}', '{suffix}', '{ext}', 'bc_process')
  params:
    primer_length = len(config['general']['PCRprimer_sequence']),
    linker1_length = len(config['general']['linker1_sequence']),
    linker2_length = len(config['general']['linker2_sequence']),
    adapt_Tn5_length = len(config['general']['adapt_Tn5']),
    spatial_barcode1_length = config['general']['spatial_barcode1_length'],
    spatial_barcode2_length = config['general']['spatial_barcode2_length'],
    nanoCutTag_barcode_length = config['general']['nanoCutTag_barcode_length']
  conda: '../envs/dbit-spatial-nanoct-rna-bcprocess.yaml'
  shell:
    '''
    python3 {input.script} \
    --input {input.in1} \
    --output_R1 {output.out1} \
    --output_R2 {output.out2} \
    --primer_length {params.primer_length} \
    --linker1_length {params.linker1_length} \
    --linker2_length {params.linker2_length} \
    --adapt_tn5_length {params.adapt_Tn5_length} \
    --spatial_barcode1_length {params.spatial_barcode1_length} \
    --spatial_barcode2_length {params.spatial_barcode2_length} \
    --nanoCT_barcode_length {params.nanoCutTag_barcode_length} \
    > {log} 2>&1
    '''

# Keep the original sequence read as R3 for debarcode.py.
rule seq_file_rename:
  input:
    in1 = lambda wildcards: qc_fastq(wildcards.sample, wildcards.number, wildcards.lane, Rfile_sequence, 'raw_qc_linker2', wildcards.suffix, wildcards.ext),
    infile = lambda wildcards: qc_done(wildcards.sample, wildcards.number, wildcards.lane, wildcards.suffix, wildcards.ext, 'filter_L2')
  output:
    out1 = tmp_fastq('{sample}', '{number}', '{lane}', 'R3', '{suffix}', '{ext}'),
    outfile = touch(tmp_done('{sample}', '{number}', '{lane}', '{suffix}', '{ext}', 'seq_file_rename'))
  log:
    sample_lane_log('{sample}', '{number}', '{lane}', '{suffix}', '{ext}', 'seq_file_rename')
  shell:
    '''
    cp {input.in1} {output.out1} > {log} 2>&1
    '''

# Split one CT lane into modality-specific FASTQs using the antibody barcode.
rule debarcode:
  input:
    script = workflow.basedir + '/scripts/debarcode.py',
    fastq = lambda wildcards: [
      tmp_fastq(wildcards.sample, wildcards.number, wildcards.lane, 'R{read}'.format(read=read), wildcards.suffix, wildcards.ext)
      for read in [1, 2, 3]
    ],
    infile1 = lambda wildcards: tmp_done(wildcards.sample, wildcards.number, wildcards.lane, wildcards.suffix, wildcards.ext, 'bc_process'),
    infile2 = lambda wildcards: tmp_done(wildcards.sample, wildcards.number, wildcards.lane, wildcards.suffix, wildcards.ext, 'seq_file_rename')
  output:
    r1 = ct_debarcoded_fastq('{sample}', '{modality}', '{barcode}', '{number}', '{lane}', 'R1', '{suffix}', '{ext}'),
    r2 = ct_debarcoded_fastq('{sample}', '{modality}', '{barcode}', '{number}', '{lane}', 'R2', '{suffix}', '{ext}'),
    r3 = ct_debarcoded_fastq('{sample}', '{modality}', '{barcode}', '{number}', '{lane}', 'R3', '{suffix}', '{ext}'),
    outfile = touch(modality_lane_done('{sample}', '{modality}', '{barcode}', '{number}', '{lane}', '{suffix}', '{ext}', 'debarcode'))
  log:
    modality_lane_log('{sample}', '{modality}', '{barcode}', '{number}', '{lane}', '{suffix}', '{ext}', 'debarcode')
  params:
    nbarcodes = len(antibodies_list),
    out_folder = lambda wildcards: proc_dir + '{sample}/{modality}_{barcode}/fastq/' \
      .format( \
        sample=wildcards.sample,
        modality=wildcards.modality,
        barcode=wildcards.barcode),
    patternTn5 = config['general']['adapt_Tn5'],
    check_outputs = workflow.basedir + '/scripts/check_outputs.py',
    flush_every = config['general'].get('debarcode_flush_every', 100000),
    min_first_flush_ratio = config['general'].get('min_first_flush_ratio', 0.00001)
  conda: '../envs/dbit-spatial-nanoct-rna-debarcode.yaml'
  shell:
    '''
    {{
    python3 {input.script} \
    --input {input.fastq} \
    --out_prefix {params.out_folder} \
    --pattern {params.patternTn5} \
    --single_cell \
    --barcode {wildcards.barcode} \
    --name {wildcards.sample} \
    --flush_every {params.flush_every} \
    --min_first_flush_ratio {params.min_first_flush_ratio} \
    && python3 {params.check_outputs} {output.r1} {output.r2} {output.r3}
    }} > {log} 2>&1
    '''

# Temporarily replace Cell Ranger's barcode whitelist with the spatial whitelist.
# The original file is backed up in processedData_dir/.done/ and restored later.
rule get_barcodes_cellranger:
  input:
    spatial_barcodes = config['general']['spatial_barcodes_file'],
  output:
    backup = cellranger_barcodes_backup(),
    outfile = touch(global_done('get_barcodes_cellranger'))
  log:
    global_log('get_barcodes_cellranger')
  params:
    script = workflow.basedir + '/scripts/replace_cellranger_barcodes.py',
    cellranger_barcodes_file = cellranger_barcodes_path()
  shell:
    '''
    python3 {params.script} \
      --spatial-barcodes {input.spatial_barcodes} \
      --cellranger-barcodes {params.cellranger_barcodes_file} \
      --backup {output.backup} > {log} 2>&1
    '''

# Restore the original Cell Ranger whitelist after every Cell Ranger job finished.
rule restore_cellranger_barcodes:
  input:
    backup = cellranger_barcodes_backup(),
    run_cellranger = [
      modality_done(sample_id, modality, barcodes_dict[sample_id][modality], 'run_cellranger') \
      for sample_id in samples_list for modality in barcodes_dict[sample_id].keys()
    ]
  output:
    outfile = touch(global_done('restore_cellranger_barcodes'))
  log:
    global_log('restore_cellranger_barcodes')
  params:
    script = workflow.basedir + '/scripts/restore_cellranger_barcodes.py',
    cellranger_barcodes_file = cellranger_barcodes_path()
  shell:
    '''
    python3 {params.script} \
      --cellranger-barcodes {params.cellranger_barcodes_file} \
      --backup {input.backup} > {log} 2>&1
    '''

# Run Cell Ranger ATAC on the debarcoded FASTQs for one CT modality.
rule run_cellranger:
  input:
    in1 = lambda wildcards: [
      ct_debarcoded_fastq(wildcards.sample, wildcards.modality, wildcards.barcode, res['number'], res['lane'], 'R1', res['suffix'], res['ext'])
      for res in get_fastq_info_from_folder(raw_dir, wildcards.sample)
    ],
    in2 = lambda wildcards: [
      ct_debarcoded_fastq(wildcards.sample, wildcards.modality, wildcards.barcode, res['number'], res['lane'], 'R2', res['suffix'], res['ext'])
      for res in get_fastq_info_from_folder(raw_dir, wildcards.sample)
    ],
    in3 = lambda wildcards: [
      ct_debarcoded_fastq(wildcards.sample, wildcards.modality, wildcards.barcode, res['number'], res['lane'], 'R3', res['suffix'], res['ext'])
      for res in get_fastq_info_from_folder(raw_dir, wildcards.sample)
    ],
    infile1 = lambda wildcards: [
      modality_lane_done(
        sample=wildcards.sample,
        modality=wildcards.modality,
        barcode=wildcards.barcode,
        number=res['number'],
        lane=res['lane'],
        suffix=res['suffix'],
        ext=res['ext'],
        name='debarcode'
      )
      for res in get_fastq_info_from_folder(raw_dir, wildcards.sample)
    ],
    infile2 = global_done('get_barcodes_cellranger')
  output:
    bam = ct_cellranger_out('{sample}', '{modality}', '{barcode}', 'possorted_bam.bam'),
    bai = ct_cellranger_out('{sample}', '{modality}', '{barcode}', 'possorted_bam.bam.bai'),
    frag = ct_cellranger_out('{sample}', '{modality}', '{barcode}', 'fragments.tsv.gz'),
    meta = ct_cellranger_out('{sample}', '{modality}', '{barcode}', 'singlecell.csv'),
    peaks = ct_cellranger_out('{sample}', '{modality}', '{barcode}', 'peaks.bed'),
    outfile = touch(modality_done('{sample}', '{modality}', '{barcode}', 'run_cellranger'))
  log:
    modality_log('{sample}', '{modality}', '{barcode}', 'run_cellranger')
  params:
    cellranger_software = config['general']['cellranger']['software_bin'],
    cellranger_ref = config['general']['cellranger']['reference_path'],
    processed_dir = proc_dir,
    cellranger_mem = config['general']['cellranger']['mem'],
    fastq_folder = ct_modality_dir('{sample}', '{modality}', '{barcode}') + '/fastq/barcode_{barcode}/',
    check_outputs = workflow.basedir + '/scripts/check_outputs.py'
  threads: config['general']['cellranger']['core']
  shell:
    '''
    {{
    rm -rf {params.processed_dir}{wildcards.sample}/{wildcards.modality}_{wildcards.barcode}/cellranger/;
    cd {params.processed_dir}{wildcards.sample}/{wildcards.modality}_{wildcards.barcode}/;
    {params.cellranger_software} count \
      --id cellranger \
      --reference {params.cellranger_ref} \
      --fastqs {params.fastq_folder} \
      --sample={wildcards.sample}\
      --localcores={threads} \
      --localmem={params.cellranger_mem}
    python3 {params.check_outputs} {output.bam} {output.bai} {output.frag} {output.meta} {output.peaks}
    }} > {log} 2>&1
    '''

# Name-sort Cell Ranger BAM so paired reads are adjacent for LA duplicate removal.
rule bam_to_namesorted:
    input:
        bam = ct_cellranger_out('{sample}', '{modality}', '{barcode}', 'possorted_bam.bam'),
        infile = modality_done('{sample}', '{modality}', '{barcode}', 'run_cellranger'),
    output:
        bam = temp(ct_cellranger_out('{sample}', '{modality}', '{barcode}', 'namesorted_bam.bam')),
        outfile = touch(modality_done('{sample}', '{modality}', '{barcode}', 'bam_to_namesorted')),
    log:
        modality_log('{sample}', '{modality}', '{barcode}', 'bam_to_namesorted')
    params:
        tempfolder = config['general']['tempdir'],
        check_outputs = workflow.basedir + '/scripts/check_outputs.py'
    threads: config['general'].get('samtools_threads', 20)
    resources:
        mem_mb = config['general'].get('samtools_mem_mb', 32000)
    conda: '../envs/dbit-spatial-nanoct-rna-samtools.yaml'
    shell:
        '''
        {{
        samtools sort -T {params.tempfolder} -@ {threads} -n -o {output.bam} {input.bam};
        python3 {params.check_outputs} {output.bam}
        }} > {log} 2>&1
        '''

# Remove linear amplification duplicates while keeping PCR duplicates.
rule remove_LA_duplicates:
    input:
        bam = ct_cellranger_out('{sample}', '{modality}', '{barcode}', 'namesorted_bam.bam'),
        infile = modality_done('{sample}', '{modality}', '{barcode}', 'bam_to_namesorted'),
    output:
        bam = temp(ct_cellranger_out('{sample}', '{modality}', '{barcode}', 'namesorted_noLA_duplicates_bam.bam')),
        outfile = touch(modality_done('{sample}', '{modality}', '{barcode}', 'remove_LA_duplicates')),
    log:
        modality_log('{sample}', '{modality}', '{barcode}', 'remove_LA_duplicates')
    params:
        script = workflow.basedir + '/scripts/remove_LA_duplicates.py',
        check_outputs = workflow.basedir + '/scripts/check_outputs.py',
    conda: '../envs/dbit-spatial-nanoct-rna-debarcode.yaml'
    resources:
        mem_mb = config['general'].get('remove_LA_duplicates_mem_mb', 32000)
    shell:
        '''
        {{
        python3 {params.script} {input.bam} {output.bam};
        python3 {params.check_outputs} {output.bam}
        }} > {log} 2>&1
        '''

# Coordinate-sort and index the no-LA BAM for downstream tools.
rule possort_noLA_bam_file:
    input:
        bam = ct_cellranger_out('{sample}', '{modality}', '{barcode}', 'namesorted_noLA_duplicates_bam.bam'),
        infile = modality_done('{sample}', '{modality}', '{barcode}', 'remove_LA_duplicates'),
    output:
        bam   = temp(ct_cellranger_out('{sample}', '{modality}', '{barcode}', 'possorted_noLA_duplicates_bam.bam')),
        index = temp(ct_cellranger_out('{sample}', '{modality}', '{barcode}', 'possorted_noLA_duplicates_bam.bam.bai')),
        outfile = touch(modality_done('{sample}', '{modality}', '{barcode}', 'possort_noLA_bam')),
    log:
        modality_log('{sample}', '{modality}', '{barcode}', 'possort_noLA_bam')
    conda: '../envs/dbit-spatial-nanoct-rna-samtools.yaml'
    threads: config['general'].get('samtools_threads', 20)
    resources:
        mem_mb = config['general'].get('samtools_mem_mb', 32000)
    params:
        tempfolder = config['general']['tempdir'],
        check_outputs = workflow.basedir + '/scripts/check_outputs.py'
    shell:
        '''
        {{
        samtools sort -@ {threads} -T {params.tempfolder} -o {output.bam} {input.bam};
        samtools index {output.bam};
        python3 {params.check_outputs} {output.bam} {output.index}
        }} > {log} 2>&1
        '''

# Convert the filtered no-LA BAM back into fragment format.
rule bam_noLA_to_fragments_noLA:
    input:
        bam = ct_cellranger_out('{sample}', '{modality}', '{barcode}', 'possorted_noLA_duplicates_bam.bam'),
        index= ct_cellranger_out('{sample}', '{modality}', '{barcode}', 'possorted_noLA_duplicates_bam.bam.bai'),
        infile = modality_done('{sample}', '{modality}', '{barcode}', 'possort_noLA_bam'),
    output:
        fragments = temp(ct_cellranger_out('{sample}', '{modality}', '{barcode}', 'fragments_noLA_duplicates.tsv')),
        outfile = touch(modality_done('{sample}', '{modality}', '{barcode}', 'noLA_fragments')),
    log:
        modality_log('{sample}', '{modality}', '{barcode}', 'noLA_fragments')
    conda: '../envs/dbit-spatial-nanoct-rna-sinto.yaml'
    threads: config['general'].get('sinto_threads', 20)
    resources:
        mem_mb=config['general'].get('sinto_mem_mb', 16000)
    params:
        check_outputs = workflow.basedir + '/scripts/check_outputs.py'
    shell:
        '''
        {{
        sinto fragments -b {input.bam} -f {output.fragments} -p {threads};
        python3 {params.check_outputs} {output.fragments}
        }} > {log} 2>&1
        '''

# Sort, bgzip, and tabix-index the no-LA fragments file.
rule sort_sinto_output:
    input:
        fragments = ct_cellranger_out('{sample}', '{modality}', '{barcode}', 'fragments_noLA_duplicates.tsv'),
        infile = modality_done('{sample}', '{modality}', '{barcode}', 'noLA_fragments'),
    output:
        fragments = ct_cellranger_out('{sample}', '{modality}', '{barcode}', 'fragments_noLA_duplicates.tsv.gz'),
        index      = ct_cellranger_out('{sample}', '{modality}', '{barcode}', 'fragments_noLA_duplicates.tsv.gz.tbi'),
        outfile = touch(modality_done('{sample}', '{modality}', '{barcode}', 'sort_noLA_fragments')),
    log:
        modality_log('{sample}', '{modality}', '{barcode}', 'sort_noLA_fragments')
    conda: '../envs/dbit-spatial-nanoct-rna-samtools.yaml'
    resources:
        mem_mb = config['general'].get('samtools_mem_mb', 16000)
    params:
        tempfolder = config['general']['tempdir'],
        check_outputs = workflow.basedir + '/scripts/check_outputs.py'
    shell:
        '''
        {{
        sort -T {params.tempfolder} -k1,1 -k2,2n {input.fragments} | bgzip > {output.fragments};
        tabix -p bed {output.fragments};
        python3 {params.check_outputs} {output.fragments} {output.index}
        }} > {log} 2>&1
        '''

# Create a normalized bigWig track from all Cell Ranger reads.
rule bam_to_bw:
    input:
        cellranger_bam = ct_cellranger_out('{sample}', '{modality}', '{barcode}', 'possorted_bam.bam'),
        cellranger_bai = ct_cellranger_out('{sample}', '{modality}', '{barcode}', 'possorted_bam.bam.bai'),
        infile = modality_done('{sample}', '{modality}', '{barcode}', 'run_cellranger'),
    output:
        bigwig = ct_bigwig('{sample}', '{modality}', '{barcode}', 'all_reads.bw'),
        outfile = touch(modality_done('{sample}', '{modality}', '{barcode}', 'bam_to_bw')),
    log:
        modality_log('{sample}', '{modality}', '{barcode}', 'bam_to_bw')
    threads: config['general'].get('bamcoverage_threads', 20)
    conda: '../envs/dbit-spatial-nanoct-rna-bamcoverage.yaml'
    resources:
        mem_mb = config['general'].get('bamcoverage_mem_mb', 16000)
    params:
        check_outputs = workflow.basedir + '/scripts/check_outputs.py'
    shell:
        '''
        {{
        bamCoverage -b {input.cellranger_bam} -o {output.bigwig} -p {threads} --minMappingQuality 5 \
          --binSize 50 --centerReads --smoothLength 250 --normalizeUsing RPKM --ignoreDuplicates --extendReads;
        python3 {params.check_outputs} {output.bigwig}
        }} > {log} 2>&1
        '''

# Call broad peaks for one CT modality.
rule run_macs_broad:
    input:
        cellranger_bam=ct_cellranger_out('{sample}', '{modality}', '{barcode}', 'possorted_bam.bam'),
        infile = modality_done('{sample}', '{modality}', '{barcode}', 'run_cellranger'),
    output:
        broad_peaks=ct_macs_broad_peak('{sample}', '{modality}', '{barcode}'),
        outfile = touch(modality_done('{sample}', '{modality}', '{barcode}', 'macs_broad')),
    log:
        modality_log('{sample}', '{modality}', '{barcode}', 'macs_broad')
    params:
        macs_outdir=ct_modality_dir('{sample}', '{modality}', '{barcode}') + '/peaks/macs_broad/',
        macs_genome=config['general']['macs_genome'],
        check_outputs = workflow.basedir + '/scripts/check_outputs.py'
    conda: '../envs/dbit-spatial-nanoct-rna-macs.yaml'
    resources:
        mem_mb = config['general'].get('macs_mem_mb', 16000)
    shell:
        '''
        {{
        macs2 callpeak -t {input.cellranger_bam} -g {params.macs_genome} -f BAMPE -n {wildcards.modality} \
          --outdir {params.macs_outdir} --llocal 100000 --keep-dup 1 --broad-cutoff 0.1 \
          --max-gap 1000 --broad;
        python3 {params.check_outputs} {output.broad_peaks}
        }} > {log} 2>&1
        '''

# Count cell barcodes among reads overlapping called peaks.
rule barcode_metrics_peaks:
    input:
        bam=ct_cellranger_out('{sample}', '{modality}', '{barcode}', 'possorted_bam.bam'),
        peaks=ct_macs_broad_peak('{sample}', '{modality}', '{barcode}'),
        infile1 = modality_done('{sample}', '{modality}', '{barcode}', 'run_cellranger'),
        infile2 = modality_done('{sample}', '{modality}', '{barcode}', 'macs_broad'),
    output:
        overlap=ct_barcode_metrics('{sample}', '{modality}', '{barcode}', 'peaks_barcodes.txt'),
        outfile = touch(modality_done('{sample}', '{modality}', '{barcode}', 'barcode_metrics_peaks')),
    log:
        modality_log('{sample}', '{modality}', '{barcode}', 'barcode_metrics_peaks')
    params:
        get_cell_barcode=workflow.basedir + '/scripts/awk/get_cell_barcode.awk',
        tmpdir=config['general']['tempdir']
    conda: '../envs/dbit-spatial-nanoct-rna-samtools.yaml'
    resources:
        mem_mb = config['general'].get('samtools_mem_mb', 16000)
    shell:
        '''
        {{
        bedtools intersect -abam {input.bam} -b {input.peaks} -u | samtools view -f2 | \
          awk -f {params.get_cell_barcode} | sed "s/CB:Z://g" | \
          sort -T {params.tmpdir} | uniq -c > {output.overlap};
        [[ -s {output.overlap} ]]
        }} > {log} 2>&1
        '''

# Count all cell barcodes in properly paired reads.
rule barcode_metrics_all:
    input:
        bam=ct_cellranger_out('{sample}', '{modality}', '{barcode}', 'possorted_bam.bam'),
        infile = modality_done('{sample}', '{modality}', '{barcode}', 'run_cellranger'),
    output:
        all_bcd=ct_barcode_metrics('{sample}', '{modality}', '{barcode}', 'all_barcodes.txt'),
        outfile = touch(modality_done('{sample}', '{modality}', '{barcode}', 'barcode_metrics_all')),
    log:
        modality_log('{sample}', '{modality}', '{barcode}', 'barcode_metrics_all')
    params:
        get_cell_barcode=workflow.basedir + '/scripts/awk/get_cell_barcode.awk',
        tmpdir=config['general']['tempdir']
    conda: '../envs/dbit-spatial-nanoct-rna-samtools.yaml'
    resources:
        mem_mb = config['general'].get('samtools_mem_mb', 16000)
    shell:
        '''
        {{
        mkdir -p {params.tmpdir};
        samtools view -f2 {input.bam} | awk -f {params.get_cell_barcode} | sed "s/CB:Z://g" | \
          sort -T {params.tmpdir} | uniq -c > {output.all_bcd};
        [[ -s {output.all_bcd} ]]
        }} > {log} 2>&1
        '''

# Remove heavy intermediate Cell Ranger folders while keeping outs/.
rule clean_cellranger_output:
    input:
        bam = ct_cellranger_out('{sample}', '{modality}', '{barcode}', 'possorted_bam.bam'),
        frag = ct_cellranger_out('{sample}', '{modality}', '{barcode}', 'fragments.tsv.gz'),
        meta = ct_cellranger_out('{sample}', '{modality}', '{barcode}', 'singlecell.csv'),
        peaks = ct_cellranger_out('{sample}', '{modality}', '{barcode}', 'peaks.bed'),
        infile = modality_done('{sample}', '{modality}', '{barcode}', 'run_cellranger'),
    output:
        outfile = touch(modality_done('{sample}', '{modality}', '{barcode}', 'clean_cellranger'))
    log:
        modality_log('{sample}', '{modality}', '{barcode}', 'clean_cellranger')
    params:
        cellranger_folder = ct_modality_dir('{sample}', '{modality}', '{barcode}') + '/cellranger/'
    shell:
        'find {params.cellranger_folder} -mindepth 1 -maxdepth 1 ! -name outs -exec rm -rf {{}} + > {log} 2>&1'

# Convert configured spatial barcodes to Cell Ranger-style cell IDs with "-1".
rule spatial_barcodes_to_cells:
    input:
        spatial_barcodes = config['general']['spatial_barcodes_file']
    output:
        cells = proc_dir + 'all_spatial_cells.txt',
        outfile = touch(global_done('all_spatial_cells')),
    log:
        global_log('all_spatial_cells')
    params:
        add_1_to_cells = workflow.basedir + '/scripts/awk/add_1_to_cells.awk'
    shell:
        '''
        {{
        awk -f {params.add_1_to_cells} {input.spatial_barcodes} > {output.cells};
        [[ -s {output.cells} ]]
        }} > {log} 2>&1
        '''

rule create_matrix_peaks:
    # Count fragments over MACS broad peaks with fragtk.
    input:
        frag  = ct_cellranger_out('{sample}', '{modality}', '{barcode}', 'fragments.tsv.gz'),
        peaks = ct_macs_broad_peak('{sample}', '{modality}', '{barcode}'),
        cells = proc_dir + 'all_spatial_cells.txt',
        infile1 = modality_done('{sample}', '{modality}', '{barcode}', 'run_cellranger'),
        infile2 = modality_done('{sample}', '{modality}', '{barcode}', 'macs_broad'),
        infile3 = global_done('all_spatial_cells'),
    output:
        folder   = directory(ct_matrix_dir('{sample}', '{modality}', '{barcode}', 'matrix_peaks')),
        outfile = touch(modality_done('{sample}', '{modality}', '{barcode}', 'matrix_peaks')),
    log:
        modality_log('{sample}', '{modality}', '{barcode}', 'matrix_peaks')
    conda: '../envs/dbit-spatial-nanoct-rna-samtools.yaml'
    params:
        matrix_dir = ct_matrix_base('{sample}', '{modality}', '{barcode}'),
        matrix_final = ct_matrix_base('{sample}', '{modality}', '{barcode}') + '/matrix_peaks',
        matrix_tmp = matrix_tmp_dir('{sample}', '{modality}', '{barcode}', 'matrix_peaks'),
        fragtk = config['general']['fragtk_bin'],
        check_outputs = workflow.basedir + '/scripts/check_outputs.py',
    shell:
        '''
        {{
        mkdir -p {params.matrix_dir};
        rm -rf {params.matrix_tmp} {output.folder};
        {params.fragtk} matrix -f {input.frag} -b {input.peaks} -c {input.cells} -o {params.matrix_tmp};
        python3 {params.check_outputs} --dirs {params.matrix_tmp};
        mv {params.matrix_tmp} {params.matrix_final}
        }} > {log} 2>&1
        '''

# Generate fixed-width genomic bins and count fragments over them with fragtk.
rule create_matrix_bins:
    input:
        bam   = ct_cellranger_out('{sample}', '{modality}', '{barcode}', 'possorted_bam.bam'),
        bai   = ct_cellranger_out('{sample}', '{modality}', '{barcode}', 'possorted_bam.bam.bai'),
        frag  = ct_cellranger_out('{sample}', '{modality}', '{barcode}', 'fragments.tsv.gz'),
        cells = proc_dir + 'all_spatial_cells.txt',
        infile1 = modality_done('{sample}', '{modality}', '{barcode}', 'run_cellranger'),
        infile2 = global_done('all_spatial_cells'),
    output:
        folder     = directory(ct_matrix_dir('{sample}', '{modality}', '{barcode}', 'matrix_bin_{bins}')),
        chromsizes = temp(ct_modality_dir('{sample}', '{modality}', '{barcode}') + '/chromsizes_{bins}.txt'),
        windows    = temp(ct_modality_dir('{sample}', '{modality}', '{barcode}') + '/windows_{bins}.txt'),
        outfile    = touch(modality_done('{sample}', '{modality}', '{barcode}', 'matrix_bin_{bins}')),
    log:
        modality_log('{sample}', '{modality}', '{barcode}', 'matrix_bin_{bins}')
    conda: '../envs/dbit-spatial-nanoct-rna-samtools.yaml'
    params:
        get_chrom_sizes = workflow.basedir + '/scripts/awk/get_chrom_sizes.awk',
        matrix_dir = ct_matrix_base('{sample}', '{modality}', '{barcode}'),
        matrix_final = ct_matrix_base('{sample}', '{modality}', '{barcode}') + '/matrix_bin_{bins}',
        matrix_tmp = matrix_tmp_dir('{sample}', '{modality}', '{barcode}', 'matrix_bin_{bins}'),
        fragtk = config['general']['fragtk_bin'],
        check_outputs = workflow.basedir + '/scripts/check_outputs.py',
    shell:
        """
        {{
        mkdir -p {params.matrix_dir};
        rm -rf {params.matrix_tmp} {output.folder};
        samtools idxstats {input.bam} | awk -f {params.get_chrom_sizes} > {output.chromsizes};
        bedtools makewindows -g {output.chromsizes} -w {wildcards.bins} > {output.windows};
        python3 {params.check_outputs} {output.chromsizes} {output.windows};
        {params.fragtk} matrix -f {input.frag} -b {output.windows} -c {input.cells} -o {params.matrix_tmp};
        python3 {params.check_outputs} --dirs {params.matrix_tmp};
        mv {params.matrix_tmp} {params.matrix_final};
        }} > {log} 2>&1
        """
    
# Build promoter-extended gene intervals and count fragments over those regions.
rule create_genebody_and_promoter_matrix:
    input:
        cellranger_gtf = config['general']['cellranger']['reference_path'] + 'genes/genes.gtf.gz',
        frag           = ct_cellranger_out('{sample}', '{modality}', '{barcode}', 'fragments.tsv.gz'),
        cells          = proc_dir + 'all_spatial_cells.txt',
        infile1        = modality_done('{sample}', '{modality}', '{barcode}', 'run_cellranger'),
        infile2        = global_done('all_spatial_cells'),
    output:
        genebody_gtf = ct_matrix_file('{sample}', '{modality}', '{barcode}', 'matrix_genes', 'genebody_and_promoter.gtf'),
        genebody_bed = ct_matrix_file('{sample}', '{modality}', '{barcode}', 'matrix_genes', 'genebody_and_promoter.bed'),
        gene_names   = ct_matrix_file('{sample}', '{modality}', '{barcode}', 'matrix_genes', 'gene_names.txt'),
        folder       = directory(ct_matrix_dir('{sample}', '{modality}', '{barcode}', 'matrix_genes')),
        outfile      = touch(modality_done('{sample}', '{modality}', '{barcode}', 'matrix_genes')),
    log:
        modality_log('{sample}', '{modality}', '{barcode}', 'matrix_genes')
    conda: '../envs/dbit-spatial-nanoct-rna-samtools.yaml'
    params:
        script = workflow.basedir + '/scripts/filter_cellranger_gtf_file.py',
        matrix_dir = ct_matrix_base('{sample}', '{modality}', '{barcode}'),
        matrix_final = ct_matrix_base('{sample}', '{modality}', '{barcode}') + '/matrix_genes',
        matrix_tmp = matrix_tmp_dir('{sample}', '{modality}', '{barcode}', 'matrix_genes'),
        fragtk = config['general']['fragtk_bin'],
        check_outputs = workflow.basedir + '/scripts/check_outputs.py',
    shell:
        """
        {{
        mkdir -p {params.matrix_dir};
        rm -rf {params.matrix_tmp} {output.folder};
        mkdir -p {params.matrix_tmp};
        python3 {params.script} -i {input.cellranger_gtf} -o {params.matrix_tmp}/genebody_and_promoter.gtf -n {params.matrix_tmp}/gene_names.txt;
        cut -f 1,4,5 {params.matrix_tmp}/genebody_and_promoter.gtf > {params.matrix_tmp}/genebody_and_promoter.bed;
        python3 {params.check_outputs} {params.matrix_tmp}/genebody_and_promoter.gtf {params.matrix_tmp}/gene_names.txt {params.matrix_tmp}/genebody_and_promoter.bed;
        {params.fragtk} matrix -f {input.frag} -b {params.matrix_tmp}/genebody_and_promoter.bed -c {input.cells} -o {params.matrix_tmp};
        python3 {params.check_outputs} --dirs {params.matrix_tmp};
        mv {params.matrix_tmp} {params.matrix_final};
        }} > {log} 2>&1
        """
