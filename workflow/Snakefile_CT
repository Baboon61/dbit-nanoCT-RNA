include: 'Snakefile_prep_CT.smk'
include: 'Snakefile_paths.smk'

#General rule
rule all:
  input:
    filterPCR=[
      qc_fastq(res['id'], res['number'], res['lane'], 'R1', 'raw_qc_primer', res['suffix'], res['ext']) \
      for sample_id in samples_list for res in get_fastq_info_from_folder(raw_dir, sample_id)
    ],
    filterL1=[
      qc_fastq(res['id'], res['number'], res['lane'], 'R1', 'raw_qc_linker1', res['suffix'], res['ext']) \
      for sample_id in samples_list for res in get_fastq_info_from_folder(raw_dir, sample_id)
    ],
    filterL2=[
      qc_fastq(res['id'], res['number'], res['lane'], 'R1', 'raw_qc_linker2', res['suffix'], res['ext']) \
      for sample_id in samples_list for res in get_fastq_info_from_folder(raw_dir, sample_id)
    ],
    bc_process=[
      tmp_fastq(res['id'], res['number'], res['lane'], 'R2', res['suffix'], res['ext']) \
      for sample_id in samples_list for res in get_fastq_info_from_folder(raw_dir, sample_id)
    ],
    seq_file_rename=[
      tmp_fastq(sample_id, res['number'], res['lane'], 'R3', res['suffix'], res['ext']) \
      for sample_id in samples_list for res in get_fastq_info_from_folder(raw_dir, sample_id)
    ],
    debarcode=[
      proc_dir + '{sample}/{modality}_{barcode}/fastq/barcode_{barcode}/{sample}_{number}_{lane}_R1_{suffix}.{ext}'.format( \
      modality=modality,barcode=barcodes_dict[res['id']][modality], sample=res['id'], number=res['number'], lane=res['lane'], suffix=res['suffix'], ext=res['ext']) \
      for sample_id in samples_list for modality in barcodes_dict[sample_id].keys() for res in get_fastq_info_from_folder(raw_dir, sample_id)
    ],
    get_barcodes_cellranger=[
      global_done('get_barcodes_cellranger')
    ],
    run_cellranger=[
      modality_done(sample_id, modality, barcodes_dict[sample_id][modality], 'run_cellranger') \
      for sample_id in samples_list for modality in barcodes_dict[sample_id].keys()
    ],
    bigwig_all=[
      modality_done(sample_id, modality, barcodes_dict[sample_id][modality], 'bam_to_bw') \
      for sample_id in samples_list for modality in barcodes_dict[sample_id].keys()
    ],
    macs_broad=[
      modality_done(sample_id, modality, barcodes_dict[sample_id][modality], 'macs_broad') \
      for sample_id in samples_list for modality in barcodes_dict[sample_id].keys()
    ],
    barcodes_sum=[
      modality_done(sample_id, modality, barcodes_dict[sample_id][modality], 'barcode_metrics_all') \
      for sample_id in samples_list for modality in barcodes_dict[sample_id].keys()
    ],
    noLA_bam=[
      modality_done(sample_id, modality, barcodes_dict[sample_id][modality], 'sort_noLA_fragments') \
      for sample_id in samples_list for modality in barcodes_dict[sample_id].keys()
    ],
    cellranger_cleanup = [
      modality_done(sample_id, modality, barcodes_dict[sample_id][modality], 'clean_cellranger') \
      for sample_id in samples_list for modality in barcodes_dict[sample_id].keys()
    ],
    matrix_peaks = [
      modality_done(sample_id, modality, barcodes_dict[sample_id][modality], 'matrix_peaks') \
      for sample_id in samples_list for modality in barcodes_dict[sample_id].keys()
    ],
    matrix_bins = [
      modality_done(sample_id, modality, barcodes_dict[sample_id][modality], 'matrix_bin_{binsize}'.format(binsize=binsize)) \
      for sample_id in samples_list for modality in barcodes_dict[sample_id].keys() for binsize in config['general']['bin_sizes']
    ],
    matrix_genes = [
      modality_done(sample_id, modality, barcodes_dict[sample_id][modality], 'matrix_genes') \
      for sample_id in samples_list for modality in barcodes_dict[sample_id].keys()
    ],

include: 'Snakefile_spatial_demux.smk'

#Create a new R2 with spatial barcode and modality barcodes
rule bc_process:
  input:
    script = workflow.basedir + '/scripts/BC_process_CT.py',
    in1 = lambda wildcards: qc_fastq(wildcards.sample, wildcards.number, wildcards.lane, Rfile_barcode, 'raw_qc_linker2', wildcards.suffix, wildcards.ext),
    infile = lambda wildcards: qc_done(wildcards.sample, wildcards.number, wildcards.lane, wildcards.suffix, wildcards.ext, 'filter_L2')
  output:
    out1 = tmp_fastq('{sample}', '{number}', '{lane}', 'R1', '{suffix}', '{ext}'),
    out2 = tmp_fastq('{sample}', '{number}', '{lane}', 'R2', '{suffix}', '{ext}'),
    outfile = touch(tmp_done('{sample}', '{number}', '{lane}', '{suffix}', '{ext}', 'bc_process'))
  params:
    primer_length = len(config['general']['PCRprimer_sequence']),
    linker1_length = len(config['general']['linker1_sequence']),
    linker2_length = len(config['general']['linker2_sequence']),
    adapt_Tn5_length = len(config['general']['adapt_Tn5']),
    spatial_barcode1_length = config['general']['spatial_barcode1_length'],
    spatial_barcode2_length = config['general']['spatial_barcode2_length'],
    nanoCutTag_barcode_length = config['general']['nanoCutTag_barcode_length']
  conda: '../envs/dbit-spatial-nanoct-rna-bcprocess.yaml'
  shell:
    '''
    python3 {input.script} \
    --input {input.in1} \
    --output_R1 {output.out1} \
    --output_R2 {output.out2} \
    --primer_length {params.primer_length} \
    --linker1_length {params.linker1_length} \
    --linker2_length {params.linker2_length} \
    --adapt_tn5_length {params.adapt_Tn5_length} \
    --spatial_barcode1_length {params.spatial_barcode1_length} \
    --spatial_barcode2_length {params.spatial_barcode2_length} \
    --nanoCT_barcode_length {params.nanoCutTag_barcode_length} \
    2>&1
    '''

#Rename the sequence file to R3
rule seq_file_rename:
  input:
    in1 = lambda wildcards: qc_fastq(wildcards.sample, wildcards.number, wildcards.lane, Rfile_sequence, 'raw_qc_linker2', wildcards.suffix, wildcards.ext),
    infile = lambda wildcards: qc_done(wildcards.sample, wildcards.number, wildcards.lane, wildcards.suffix, wildcards.ext, 'filter_L2')
  output:
    out1 = tmp_fastq('{sample}', '{number}', '{lane}', 'R3', '{suffix}', '{ext}'),
    outfile = touch(tmp_done('{sample}', '{number}', '{lane}', '{suffix}', '{ext}', 'seq_file_rename'))
  shell:
    '''
    cp {input.in1} {output.out1}
    '''

#Debarcode the modality barcodes
rule debarcode:
  input:
    script = workflow.basedir + '/scripts/debarcode.py',
    fastq = lambda wildcards: [
      tmp_fastq(wildcards.sample, wildcards.number, wildcards.lane, 'R{read}'.format(read=read), wildcards.suffix, wildcards.ext)
      for read in [1, 2, 3]
    ],
    infile1 = lambda wildcards: tmp_done(wildcards.sample, wildcards.number, wildcards.lane, wildcards.suffix, wildcards.ext, 'bc_process'),
    infile2 = lambda wildcards: tmp_done(wildcards.sample, wildcards.number, wildcards.lane, wildcards.suffix, wildcards.ext, 'seq_file_rename')
  output:
    proc_dir + '{sample}/{modality}_{barcode}/fastq/barcode_{barcode}/{sample}_{number}_{lane}_R1_{suffix}.{ext}',
    proc_dir + '{sample}/{modality}_{barcode}/fastq/barcode_{barcode}/{sample}_{number}_{lane}_R2_{suffix}.{ext}',
    proc_dir + '{sample}/{modality}_{barcode}/fastq/barcode_{barcode}/{sample}_{number}_{lane}_R3_{suffix}.{ext}',
    outfile = touch(modality_lane_done('{sample}', '{modality}', '{barcode}', '{number}', '{lane}', '{suffix}', '{ext}', 'debarcode'))
  params:
    nbarcodes = len(antibodies_list),
    out_folder = lambda wildcards: proc_dir + '{sample}/{modality}_{barcode}/fastq/' \
      .format( \
        sample=wildcards.sample,
        modality=wildcards.modality,
        barcode=wildcards.barcode),
    patternTn5 = config['general']['adapt_Tn5']
  conda: '../envs/dbit-spatial-nanoct-rna-debarcode.yaml'
  shell:
    '''
    python3 {input.script} \
    --input {input.fastq} \
    --out_prefix {params.out_folder} \
    --pattern {params.patternTn5} \
    --single_cell \
    --barcode {wildcards.barcode} \
    --name {wildcards.sample} \
    2>&1
    '''

#Replace the cellranger barcodes list
rule get_barcodes_cellranger:
  input:
    spatial_barcodes = config['general']['spatial_barcodes_file'],
  output:
    cellranger_barcodes_file = config['general']['cellranger']['barcodes_path'] + config['general']['cellranger']['barcodes_file'],
    outfile = touch(global_done('get_barcodes_cellranger'))
  params:
    get_spatial_barcodes=workflow.basedir + '/scripts/awk/get_spatial_barcodes.awk',
  shell:
    'awk -f {params.get_spatial_barcodes} {input.spatial_barcodes} | gzip -cvf - > {output.cellranger_barcodes_file};'

#Run cellranger
rule run_cellranger:
  input:
    in1 = lambda wildcards: [
      proc_dir + '{sample}/{modality}_{barcode}/fastq/barcode_{barcode}/{sample}_{number}_{lane}_R1_{suffix}.{ext}'.format(
        sample=wildcards.sample,
        modality=wildcards.modality,
        barcode=wildcards.barcode,
        number=res['number'],
        lane=res['lane'],
        suffix=res['suffix'],
        ext=res['ext']
      )
      for res in get_fastq_info_from_folder(raw_dir, wildcards.sample)
    ],
    in2 = lambda wildcards: [
      proc_dir + '{sample}/{modality}_{barcode}/fastq/barcode_{barcode}/{sample}_{number}_{lane}_R2_{suffix}.{ext}'.format(
        sample=wildcards.sample,
        modality=wildcards.modality,
        barcode=wildcards.barcode,
        number=res['number'],
        lane=res['lane'],
        suffix=res['suffix'],
        ext=res['ext']
      )
      for res in get_fastq_info_from_folder(raw_dir, wildcards.sample)
    ],
    in3 = lambda wildcards: [
      proc_dir + '{sample}/{modality}_{barcode}/fastq/barcode_{barcode}/{sample}_{number}_{lane}_R3_{suffix}.{ext}'.format(
        sample=wildcards.sample,
        modality=wildcards.modality,
        barcode=wildcards.barcode,
        number=res['number'],
        lane=res['lane'],
        suffix=res['suffix'],
        ext=res['ext']
      )
      for res in get_fastq_info_from_folder(raw_dir, wildcards.sample)
    ],
    infile1 = lambda wildcards: [
      modality_lane_done(
        sample=wildcards.sample,
        modality=wildcards.modality,
        barcode=wildcards.barcode,
        number=res['number'],
        lane=res['lane'],
        suffix=res['suffix'],
        ext=res['ext'],
        name='debarcode'
      )
      for res in get_fastq_info_from_folder(raw_dir, wildcards.sample)
    ],
    infile2 = global_done('get_barcodes_cellranger')
  output:
    bam = proc_dir + '{sample}/{modality}_{barcode}/cellranger/outs/possorted_bam.bam',
    bai = proc_dir + '{sample}/{modality}_{barcode}/cellranger/outs/possorted_bam.bam.bai',
    frag = proc_dir + '{sample}/{modality}_{barcode}/cellranger/outs/fragments.tsv.gz',
    meta = proc_dir + '{sample}/{modality}_{barcode}/cellranger/outs/singlecell.csv',
    peaks = proc_dir + '{sample}/{modality}_{barcode}/cellranger/outs/peaks.bed',
    outfile = touch(modality_done('{sample}', '{modality}', '{barcode}', 'run_cellranger'))
  params:
    cellranger_software = config['general']['cellranger']['software_bin'],
    cellranger_ref = config['general']['cellranger']['reference_path'],
    processed_dir = proc_dir,
    cellranger_mem = config['general']['cellranger']['mem'],
    fastq_folder = proc_dir + '{sample}/{modality}_{barcode}/fastq/barcode_{barcode}/'
  threads: config['general']['cellranger']['core']
  shell:
    '''
    rm -rf {params.processed_dir}{wildcards.sample}/{wildcards.modality}_{wildcards.barcode}/cellranger/;
    cd {params.processed_dir}{wildcards.sample}/{wildcards.modality}_{wildcards.barcode}/;
    {params.cellranger_software} count \
      --id cellranger \
      --reference {params.cellranger_ref} \
      --fastqs {params.fastq_folder} \
      --sample={wildcards.sample}\
      --localcores={threads} \
      --localmem={params.cellranger_mem}
    '''

rule bam_to_namesorted:
    input:
        bam = proc_dir + '{sample}/{modality}_{barcode}/cellranger/outs/possorted_bam.bam',
        infile = modality_done('{sample}', '{modality}', '{barcode}', 'run_cellranger'),
    output:
        bam = temp(proc_dir + '{sample}/{modality}_{barcode}/cellranger/outs/namesorted_bam.bam'),
        outfile = touch(modality_done('{sample}', '{modality}', '{barcode}', 'bam_to_namesorted')),
    params:
        tempfolder = config['general']['tempdir']
    threads: 20
    resources:
        mem_mb = 32000
    conda: '../envs/dbit-spatial-nanoct-rna-samtools.yaml'
    shell:
        'samtools sort -T {params.tempfolder} -@ {threads} -n -o {output.bam} {input.bam} '

rule remove_LA_duplicates:
    input:
        bam = proc_dir + '{sample}/{modality}_{barcode}/cellranger/outs/namesorted_bam.bam',
        infile = modality_done('{sample}', '{modality}', '{barcode}', 'bam_to_namesorted'),
    output:
        bam = temp(proc_dir + '{sample}/{modality}_{barcode}/cellranger/outs/namesorted_noLA_duplicates_bam.bam'),
        outfile = touch(modality_done('{sample}', '{modality}', '{barcode}', 'remove_LA_duplicates')),
    params:
        script = workflow.basedir + '/scripts/remove_LA_duplicates.py',
    conda: '../envs/dbit-spatial-nanoct-rna-debarcode.yaml'
    resources:
        mem_mb = 32000
    shell:
        'python3 {params.script} {input.bam} {output.bam}'

rule possort_noLA_bam_file:
    input:
        bam = proc_dir + '{sample}/{modality}_{barcode}/cellranger/outs/namesorted_noLA_duplicates_bam.bam',
        infile = modality_done('{sample}', '{modality}', '{barcode}', 'remove_LA_duplicates'),
    output:
        bam   = temp(proc_dir + '{sample}/{modality}_{barcode}/cellranger/outs/possorted_noLA_duplicates_bam.bam'),
        index = temp(proc_dir + '{sample}/{modality}_{barcode}/cellranger/outs/possorted_noLA_duplicates_bam.bam.bai'),
        outfile = touch(modality_done('{sample}', '{modality}', '{barcode}', 'possort_noLA_bam')),
    conda: '../envs/dbit-spatial-nanoct-rna-samtools.yaml'
    threads: 20
    resources:
        mem_mb = 32000
    params:
        tempfolder = config['general']['tempdir']
    shell:
        'samtools sort -@ {threads} -T {params.tempfolder} -o {output.bam} {input.bam}; '
        'samtools index {output.bam} '

rule bam_noLA_to_fragments_noLA:
    input:
        bam = proc_dir + '{sample}/{modality}_{barcode}/cellranger/outs/possorted_noLA_duplicates_bam.bam',
        index= proc_dir + '{sample}/{modality}_{barcode}/cellranger/outs/possorted_noLA_duplicates_bam.bam.bai',
        infile = modality_done('{sample}', '{modality}', '{barcode}', 'possort_noLA_bam'),
    output:
        fragments = temp(proc_dir + '{sample}/{modality}_{barcode}/cellranger/outs/fragments_noLA_duplicates.tsv'),
        outfile = touch(modality_done('{sample}', '{modality}', '{barcode}', 'noLA_fragments')),
    conda: '../envs/dbit-spatial-nanoct-rna-sinto.yaml'
    threads: 20
    resources:
        mem_mb=16000
    shell:
        'sinto fragments -b {input.bam} -f {output.fragments} -p {threads}'

rule sort_sinto_output:
    input:
        fragments = proc_dir + '{sample}/{modality}_{barcode}/cellranger/outs/fragments_noLA_duplicates.tsv',
        infile = modality_done('{sample}', '{modality}', '{barcode}', 'noLA_fragments'),
    output:
        fragments = proc_dir + '{sample}/{modality}_{barcode}/cellranger/outs/fragments_noLA_duplicates.tsv.gz',
        index      = proc_dir + '{sample}/{modality}_{barcode}/cellranger/outs/fragments_noLA_duplicates.tsv.gz.tbi',
        outfile = touch(modality_done('{sample}', '{modality}', '{barcode}', 'sort_noLA_fragments')),
    conda: '../envs/dbit-spatial-nanoct-rna-samtools.yaml'
    resources:
        mem_mb = 16000
    shell:
        'sort -k1,1 -k2,2n {input.fragments} | bgzip > {output.fragments}; '
        'tabix -p bed {output.fragments} '

rule bam_to_bw:
    input:
        cellranger_bam = proc_dir + '{sample}/{modality}_{barcode}/cellranger/outs/possorted_bam.bam',
        cellranger_bai = proc_dir + '{sample}/{modality}_{barcode}/cellranger/outs/possorted_bam.bam.bai',
        infile = modality_done('{sample}', '{modality}', '{barcode}', 'run_cellranger'),
    output:
        bigwig = proc_dir + '{sample}/{modality}_{barcode}/bigwig/all_reads.bw',
        outfile = touch(modality_done('{sample}', '{modality}', '{barcode}', 'bam_to_bw')),
    threads: 20
    conda: '../envs/dbit-spatial-nanoct-rna-bamcoverage.yaml'
    resources:
        mem_mb = 16000
    shell:
        'bamCoverage -b {input.cellranger_bam} -o {output.bigwig} -p {threads} --minMappingQuality 5 '
        ' --binSize 50 --centerReads --smoothLength 250 --normalizeUsing RPKM --ignoreDuplicates --extendReads'

rule run_macs_broad:
    input:
        cellranger_bam=proc_dir + '{sample}/{modality}_{barcode}/cellranger/outs/possorted_bam.bam',
        infile = modality_done('{sample}', '{modality}', '{barcode}', 'run_cellranger'),
    output:
        broad_peaks=proc_dir + '{sample}/{modality}_{barcode}/peaks/macs_broad/{modality}_peaks.broadPeak',
        outfile = touch(modality_done('{sample}', '{modality}', '{barcode}', 'macs_broad')),
    params:
        macs_outdir=proc_dir + '{sample}/{modality}_{barcode}/peaks/macs_broad/',
        macs_genome=config['general']['macs_genome']
    conda: '../envs/dbit-spatial-nanoct-rna-macs.yaml'
    resources:
        mem_mb = 16000
    shell:
        'macs2 callpeak -t {input.cellranger_bam} -g {params.macs_genome} -f BAMPE -n {wildcards.modality} '
        '--outdir {params.macs_outdir} --llocal 100000 --keep-dup 1 --broad-cutoff 0.1 '
        '--max-gap 1000 --broad 2>&1 '

rule barcode_metrics_peaks:
    input:
        bam=proc_dir + '{sample}/{modality}_{barcode}/cellranger/outs/possorted_bam.bam',
        peaks=proc_dir + '{sample}/{modality}_{barcode}/peaks/macs_broad/{modality}_peaks.broadPeak',
        infile1 = modality_done('{sample}', '{modality}', '{barcode}', 'run_cellranger'),
        infile2 = modality_done('{sample}', '{modality}', '{barcode}', 'macs_broad'),
    output:
        overlap=proc_dir + '{sample}/{modality}_{barcode}/barcode_metrics/peaks_barcodes.txt',
        outfile = touch(modality_done('{sample}', '{modality}', '{barcode}', 'barcode_metrics_peaks')),
    params:
        get_cell_barcode=workflow.basedir + '/scripts/awk/get_cell_barcode.awk',
        tmpdir=config['general']['tempdir']
    conda: '../envs/dbit-spatial-nanoct-rna-samtools.yaml'
    resources:
        mem_mb = 16000
    shell:
        'bedtools intersect -abam {input.bam} -b {input.peaks} -u | samtools view -f2 | '
        'awk -f {params.get_cell_barcode} | sed "s/CB:Z://g" |  '
        'sort -T {params.tmpdir} | uniq -c > {output.overlap} && [[ -s {output.overlap} ]] ; '

rule barcode_metrics_all:
    input:
        bam=proc_dir + '{sample}/{modality}_{barcode}/cellranger/outs/possorted_bam.bam',
        infile = modality_done('{sample}', '{modality}', '{barcode}', 'run_cellranger'),
    output:
        all_bcd=proc_dir + '{sample}/{modality}_{barcode}/barcode_metrics/all_barcodes.txt',
        outfile = touch(modality_done('{sample}', '{modality}', '{barcode}', 'barcode_metrics_all')),
    params:
        get_cell_barcode=workflow.basedir + '/scripts/awk/get_cell_barcode.awk',
        tmpdir=config['general']['tempdir']
    conda: '../envs/dbit-spatial-nanoct-rna-samtools.yaml'
    resources:
        mem_mb = 16000
    shell:
        'mkdir -p {params.tmpdir}; '
        'samtools view -f2 {input.bam}| '
        'awk -f {params.get_cell_barcode} | sed "s/CB:Z://g" |  '
        'sort -T {params.tmpdir} | uniq -c > {output.all_bcd} && [[ -s {output.all_bcd} ]] ; '

rule clean_cellranger_output:
    input:
        bam = proc_dir + '{sample}/{modality}_{barcode}/cellranger/outs/possorted_bam.bam',
        frag = proc_dir + '{sample}/{modality}_{barcode}/cellranger/outs/fragments.tsv.gz',
        meta = proc_dir + '{sample}/{modality}_{barcode}/cellranger/outs/singlecell.csv',
        peaks = proc_dir + '{sample}/{modality}_{barcode}/cellranger/outs/peaks.bed',
        infile = modality_done('{sample}', '{modality}', '{barcode}', 'run_cellranger'),
    output:
        outfile = touch(modality_done('{sample}', '{modality}', '{barcode}', 'clean_cellranger'))
    params:
        cellranger_folder = proc_dir + '{sample}/{modality}_{barcode}/cellranger/'
    shell:
        'find {params.cellranger_folder} -mindepth 1 -maxdepth 1 ! -name outs -exec rm -rf {{}} +; '

rule spatial_barcodes_to_cells:
    input:
        spatial_barcodes = config['general']['spatial_barcodes_file']
    output:
        cells = proc_dir + 'all_spatial_cells.txt',
        outfile = touch(global_done('all_spatial_cells')),
    params:
        add_1_to_cells = workflow.basedir + '/scripts/awk/add_1_to_cells.awk'
    shell:
        'awk -f {params.add_1_to_cells} {input.spatial_barcodes} > {output.cells}'

rule create_matrix_peaks:
    # Requires fragtk installation (https://github.com/stuart-lab/fragtk)
    input:
        frag  = proc_dir + '{sample}/{modality}_{barcode}/cellranger/outs/fragments.tsv.gz',
        peaks = proc_dir + '{sample}/{modality}_{barcode}/peaks/macs_broad/{modality}_peaks.broadPeak',
        cells = proc_dir + 'all_spatial_cells.txt',
        infile1 = modality_done('{sample}', '{modality}', '{barcode}', 'run_cellranger'),
        infile2 = modality_done('{sample}', '{modality}', '{barcode}', 'macs_broad'),
        infile3 = global_done('all_spatial_cells'),
    output:
        folder   = directory(proc_dir + '{sample}/{modality}_{barcode}/matrix/matrix_peaks/'),
        outfile = touch(modality_done('{sample}', '{modality}', '{barcode}', 'matrix_peaks')),
    conda: '../envs/dbit-spatial-nanoct-rna-samtools.yaml'
    params:
        matrix_dir = proc_dir + '{sample}/{modality}_{barcode}/matrix/',
        fragtk = config['general']['fragtk_bin'],
    shell:
        'mkdir -p {params.matrix_dir};'
        '{params.fragtk} matrix -f {input.frag} -b {input.peaks} -c {input.cells} -o {output.folder}'

rule create_matrix_bins:
    input:
        bam   = proc_dir + '{sample}/{modality}_{barcode}/cellranger/outs/possorted_bam.bam',
        bai   = proc_dir + '{sample}/{modality}_{barcode}/cellranger/outs/possorted_bam.bam.bai',
        frag  = proc_dir + '{sample}/{modality}_{barcode}/cellranger/outs/fragments.tsv.gz',
